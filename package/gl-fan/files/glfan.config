
config globals 'globals'
	# On stock OpenWrt the kernel thermal governor (step_wise) already drives
	# this fan, so the service is disabled by default. Set enabled '1' to hand
	# control to gl_fan; the init script then switches the thermal zone to the
	# user_space governor so the kernel stops overriding it.
	option enabled '0'
	option sysfs '/sys/devices/virtual/thermal/thermal_zone0/temp'
	# thermal sysfs reports millidegrees Celsius
	option div '1000'
	# Curve for the 4-speed pwm-fan (cooling_device0, cur_state 0-3).
	# Proportional control ramps the fan ABOVE 'temperature'; with the
	# defaults below the fan is off under 70 C, then state 1 @70, 2 @80,
	# 3 (max) @90 C. Lower 'temperature' to spin up sooner, raise
	# 'proportion' for a steeper ramp. 'integration'/'differential' are
	# available but default off (the fan is too coarse to benefit).
	option temperature '60'
	option proportion '0.1'
